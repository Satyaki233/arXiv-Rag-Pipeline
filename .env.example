# Copy this file to `.env` and fill in your values.
#   cp .env.example .env

# --- Where Claude runs ---
#   foundry   -> route through Microsoft/Azure AI Foundry (default)
#   anthropic -> direct Anthropic API
LLM_PROVIDER=foundry

# --- Azure Foundry (used when LLM_PROVIDER=foundry) ---
AZURE_FOUNDRY_API_KEY=your-foundry-api-key
#
# Provide ONE of the following two (not both):
#
# (A) Just the resource name. The SDK builds:
#       https://<resource>.services.ai.azure.com/anthropic/
#     Use this only if your portal endpoint is on that exact domain.
AZURE_FOUNDRY_RESOURCE=your-foundry-resource-name
#
# (B) The full base URL copied verbatim from the Foundry portal (recommended if
#     your endpoint is on a different domain, e.g. *.openai.azure.com). Include
#     the path up to (but not including) /v1. Leave (A) blank if you use this.
# AZURE_FOUNDRY_BASE_URL=https://<resource>.services.ai.azure.com/anthropic/

# The model DEPLOYMENT name you created in Foundry.
# claude-haiku-4-5 -> cheap + fast, great for grounded RAG Q&A (default)
# claude-sonnet-5  -> step up if answers need more nuance
# claude-opus-4-8  -> most capable, only if you really need it
CLAUDE_MODEL=claude-haiku-4-5

# --- Direct Anthropic API (only used when LLM_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...
